# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional — comma-separated allowlist of Telegram user IDs.
# Get your ID by DM'ing @userinfobot on Telegram.
# Leave empty to accept from anyone who DMs the bot (fine if the bot is private).
ALLOWED_USER_IDS=

# Optional — whisper transcription settings (only if openai-whisper is installed)
# Models: tiny, base, small, medium, large. base is a good speed/quality balance.
WHISPER_MODEL=base
# Leave blank for auto-detect. Set "ko" for Korean-only, "en" for English-only.
WHISPER_LANGUAGE=
